
<View>
  <Style>
    .ls-labels { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .header-adv { color: #d32f2f; border-bottom: 2px solid #d32f2f; margin-top: 20px; }
    .header-des { color: #1976d2; border-bottom: 2px solid #1976d2; margin-top: 20px; }
  </Style>

  <Header value="🔴 PROFIL DE L'ANNONCEUR (ADVERTISER)" class="header-adv"/>
  
  <Labels name="label_adv" toName="text">
    <Label value="ADV_NAME" background="#D3D3D3"/>
    <Label value="ADV_SEX" background="#800080"/>
    <Label value="ADV_AGE" background="#FFA500"/>
    <Label value="ADV_HEIGHT" background="#008000"/>
    <Label value="ADV_WEIGHT" background="#008080"/>
    <Label value="ADV_PHYSICAL_APPEARANCE" background="#E9967A"/>
    
    <Label value="ADV_PRIMARY_COUNTRY_OF_RESIDENCE" background="#FF0000"/>
    <Label value="ADV_COUNTRY_OF_ORIGIN" background="#FF6347"/>
    <Label value="ADV_OTHER_LOCATIONS_MENTIONED" background="#FF4500"/>
    
    <Label value="ADV_SECTOR_OF_ACTIVITY" background="#4682B4"/>
    <Label value="ADV_ECONOMIC_SITUATION" background="#B0C4DE"/>
    <Label value="ADV_EDUCATION_LEVEL" background="#6495ED"/>
    
    <Label value="ADV_MARITAL_STATUS" background="#9370DB"/>
    <Label value="ADV_HAS_CHILDREN" background="#20B2AA"/>
    <Label value="ADV_NUMBER_OF_CHILDREN" background="#2E8B57"/>
    <Label value="ADV_RELIGION" background="#DAA520"/>
    
    <Label value="ADV_QUALITY" background="#FF1493"/>
    <Label value="ADV_VALUES" background="#C71585"/>
    <Label value="ADV_DEFECTS" background="#A9A9A9"/>
    <Label value="ADV_INTERESTS" background="#7B68EE"/>
    <Label value="ADV_ILLNESS" background="#DC143C"/>
    
    <Label value="ADV_RELATIONSHIP_CRITERIA" background="#0000FF"/>
  </Labels>

  <Header value="🔵 PROFIL RECHERCHÉ (DESIRED)" class="header-des"/>
  
  <Labels name="label_des" toName="text">
    <Label value="DES_NAME" background="#BDBDBD"/>
    <Label value="DES_SEX" background="#4B0082"/>
    <Label value="DES_AGE" background="#CC8400"/>
    <Label value="DES_HEIGHT" background="#006400"/>
    <Label value="DES_WEIGHT" background="#005A5A"/>
    <Label value="DES_PHYSICAL_APPEARANCE" background="#D2691E"/>
    
    <Label value="DES_PRIMARY_COUNTRY_OF_RESIDENCE" background="#B22222"/>
    <Label value="DES_COUNTRY_OF_ORIGIN" background="#CD5C5C"/>
    <Label value="DES_OTHER_LOCATIONS_MENTIONED" background="#D2691E"/>
    
    <Label value="DES_SECTOR_OF_ACTIVITY" background="#2F4F4F"/>
    <Label value="DES_ECONOMIC_SITUATION" background="#778899"/>
    <Label value="DES_EDUCATION_LEVEL" background="#4169E1"/>
    
    <Label value="DES_MARITAL_STATUS" background="#483D8B"/>
    <Label value="DES_HAS_CHILDREN" background="#008B8B"/>
    <Label value="DES_NUMBER_OF_CHILDREN" background="#1E4D2B"/>
    <Label value="DES_RELIGION" background="#B8860B"/>
    
    <Label value="DES_QUALITY" background="#8B008B"/>
    <Label value="DES_VALUES" background="#800080"/>
    <Label value="DES_DEFECTS" background="#696969"/>
    <Label value="DES_INTERESTS" background="#483D8B"/>
    <Label value="DES_ILLNESS" background="#8B0000"/>
    
    <Label value="DES_RELATIONSHIP_CRITERIA" background="#0000FF"/>
  </Labels>
  
  <Header value="TEXTE DE L'ANNONCE"/>
  <Text name="text" value="$text"/>
</View>
